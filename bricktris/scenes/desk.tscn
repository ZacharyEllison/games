[gd_scene load_steps=5 format=3]

[sub_resource type="BoxMesh" id="BoxMesh_1"]
size = Vector3(1.6, 0.02, 1.6)

[sub_resource type="BoxShape3D" id="BoxShape3D_1"]
size = Vector3(1.6, 0.02, 1.6)

[sub_resource type="Shader" id="Shader_1"]
code = "shader_type spatial;
render_mode unshaded;
uniform vec4 bg_color : source_color = vec4(0.15, 0.17, 0.22, 1.0);
uniform vec4 line_color : source_color = vec4(0.32, 0.36, 0.46, 1.0);
uniform vec4 stud_color : source_color = vec4(0.4, 0.44, 0.54, 1.0);
uniform vec2 grid_origin = vec2(0.0, -0.8);
uniform float cell_size = 0.0795;
uniform float line_width = 0.003;
uniform float stud_radius = 0.011;
varying vec3 world_pos;
void vertex() {
	world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
}
void fragment() {
	vec2 f = fract((world_pos.xz - grid_origin) / cell_size);
	float lw = line_width / cell_size;
	float on_line = clamp(
		step(1.0 - lw, f.x) + step(f.x, lw) +
		step(1.0 - lw, f.y) + step(f.y, lw),
		0.0, 1.0);
	vec2 d = f - 0.5;
	float on_stud = step(length(d), stud_radius / cell_size);
	vec3 col = mix(bg_color.rgb, line_color.rgb, on_line);
	col = mix(col, stud_color.rgb, on_stud * (1.0 - on_line));
	ALBEDO = col;
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_1"]
shader = SubResource("Shader_1")

[node name="Desk" type="StaticBody3D"]
position = Vector3(0, 0.8, -0.8)
collision_layer = 1
collision_mask = 0

[node name="DeskMesh" type="MeshInstance3D" parent="."]
