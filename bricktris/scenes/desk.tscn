[node name="DeskMesh" type="MeshInstance3D" parent="."]
mesh = SubResource("BoxMesh_1")
surface_material_override/0 = SubResource("ShaderMaterial_1")

[node name="DeskShape" type="CollisionShape3D" parent="."]
